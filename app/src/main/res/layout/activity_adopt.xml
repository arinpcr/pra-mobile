<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_gradient_start">

    <LinearLayout
        android:id="@+id/top_bar_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginHorizontal="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/btn_back_adopt"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/ic_back"
            app:tint="@color/login_bg"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:src="@drawable/img_profil_user" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="12dp"
            android:background="@drawable/bg_search_bar"
            android:gravity="center_vertical"
            android:paddingHorizontal="15dp">

            <EditText
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Search"
                android:textColorHint="@color/login_bg"
                android:textSize="12sp" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_search"
                app:tint="@color/login_bg" />
        </LinearLayout>

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_chat"
            android:layout_marginEnd="12dp" />

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_all" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/greeting_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/top_bar_row"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="25dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hi,"
            android:fontFamily="@font/poppins_bold"
            android:textSize="32sp"
            android:textColor="@color/login_bg" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Good Morning !"
            android:fontFamily="@font/poppins_bold"
            android:textSize="16sp"
            android:textColor="@color/login_bg" />
    </LinearLayout>


    <LinearLayout
        android:id="@+id/category_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/greeting_section"
        android:layout_marginTop="25dp"
        android:paddingHorizontal="20dp"
        android:orientation="horizontal">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="55dp" android:layout_height="55dp" android:src="@drawable/ic_all" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="All" android:textSize="12sp" android:textColor="@color/login_bg" android:fontFamily="@font/poppins_bold"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="55dp" android:layout_height="55dp" android:src="@drawable/ic_dog" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dog" android:textSize="12sp" android:textColor="@color/login_bg" android:fontFamily="@font/poppins_bold"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="55dp" android:layout_height="55dp" android:src="@drawable/ic_cat" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cats" android:textSize="12sp" android:textColor="@color/login_bg" android:fontFamily="@font/poppins_bold"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="55dp" android:layout_height="55dp" android:src="@drawable/ic_bird" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Birds" android:textSize="12sp" android:textColor="@color/login_bg" android:fontFamily="@font/poppins_bold"/>
        </LinearLayout>
    </LinearLayout>


    <TextView
        android:id="@+id/tv_title_adopt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/category_section"
        android:layout_marginStart="20dp"
        android:layout_marginTop="25dp"
        android:text="Adopt Pet"
        android:fontFamily="@font/poppins_bold"
        android:textSize="22sp"
        android:textColor="@color/login_bg" />


    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tv_title_adopt"
        android:layout_marginHorizontal="10dp"
        android:layout_marginTop="10dp"
        android:columnCount="2">

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="220dp"
            android:layout_columnWeight="1"
            android:layout_margin="10dp"
            app:cardCornerRadius="25dp"
            app:cardBackgroundColor="@color/adopt_blue">
            <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent" android:padding="12dp">
                <ImageView
                    android:id="@+id/img_j"
                    android:layout_width="match_parent"
                    android:layout_height="130dp"
                    android:src="@drawable/img_jackson"
                    android:scaleType="centerCrop"/>
                <TextView
                    android:id="@+id/name_j"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/img_j"
                    android:layout_marginTop="10dp"
                    android:text="Jackson"
                    android:textColor="@color/black"
                    android:fontFamily="@font/poppins_bold"
                    android:textSize="16sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/name_j"
                    android:text="Distance (5km)"
                    android:textSize="10sp"
                    android:textColor="@color/login_bg" />
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_alignParentEnd="true"
                    android:layout_alignBottom="@id/name_j"
                    android:src="@drawable/ic_heart_red" />
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="220dp"
            android:layout_columnWeight="1"
            android:layout_margin="10dp"
            app:cardCornerRadius="25dp"
            app:cardBackgroundColor="@color/adopt_purple">
            <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent" android:padding="12dp">
                <ImageView
                    android:id="@+id/img_s"
                    android:layout_width="match_parent"
                    android:layout_height="130dp"
                    android:src="@drawable/img_shelly"
                    android:scaleType="centerCrop"/>
                <TextView
                    android:id="@+id/name_s"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/img_s"
                    android:layout_marginTop="10dp"
                    android:text="Shelly"
                    android:textColor="@color/black"
                    android:fontFamily="@font/poppins_bold"
                    android:textSize="16sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/name_s"
                    android:text="Distance (2km)"
                    android:textSize="10sp"
                    android:textColor="@color/login_bg" />
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_alignParentEnd="true"
                    android:layout_alignBottom="@id/name_s"
                    android:src="@drawable/ic_heart_outline" />
            </RelativeLayout>
        </androidx.cardview.widget.CardView>
    </GridLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"
        android:background="@drawable/bg_btn_gradient"
        android:orientation="horizontal"
        android:gravity="center">
        <ImageView android:layout_width="30dp" android:layout_height="30dp" android:src="@drawable/ic_home" android:layout_weight="1"/>
        <ImageView android:id="@+id/btn_to_map" android:layout_width="30dp" android:layout_height="30dp" android:src="@drawable/ic_map" android:layout_weight="1"/>
        <ImageView android:layout_width="30dp" android:layout_height="30dp" android:src="@drawable/ic_chat" android:layout_weight="1"/>
        <ImageView android:layout_width="30dp" android:layout_height="30dp" android:src="@drawable/ic_profile" android:layout_weight="1"/>
    </LinearLayout>

</RelativeLayout>