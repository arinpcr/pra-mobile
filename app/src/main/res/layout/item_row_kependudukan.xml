<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <View
            android:id="@+id/indicatorIcon"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/bg_btn_gradient"
            android:layout_marginEnd="16dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTitleRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/pink"
                android:textSize="15sp"
                android:text="Nama Utama" />

            <TextView
                android:id="@+id/tvSubtitleRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/login_bg"
                android:textSize="13sp"
                android:layout_marginTop="2dp"
                android:text="Keterangan Subtitle" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvBadgeRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_bold"
            android:textColor="#888888"
            android:textSize="12sp"
            android:text="Badge/Tanggal" />
    </LinearLayout>
</androidx.cardview.widget.CardView>